---
const steps = [
  {
    number: '01',
    title: 'Fill out the form',
    description: 'Tell us a bit about yourself—your school, your interests, and what you\'re looking for. It takes less than a minute.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`
  },
  {
    number: '02',
    title: 'Find your track',
    description: 'Explore our three paths: real coding experience, career mentorship, or student community. Pick what fits you best.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>`
  },
  {
    number: '03',
    title: 'Get matched',
    description: 'After we review your background, we will pair you with a mentor who matches your background.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`
  },
  {
    number: '04',
    title: 'Build relationships',
    description: 'Grow alongside mentors and fellow students. Get guidance, make friends, and build a network that lasts.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`
  }
];
---

<section id="how-it-works" class="py-20 sm:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-warm-900 mb-4">
        How it works
      </h2>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto">
        No hoops. Just apply below, pick your track, and start growing.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="relative">
          <!-- Connector line (hidden on mobile, shown between items on desktop) -->
          {index < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-1/2 w-full h-0.5 bg-grove-200"></div>
          )}
          
          <div class="relative bg-warm-50 rounded-2xl p-6 h-full">
            <!-- Step number -->
            <div class="w-16 h-16 bg-grove-100 rounded-xl flex items-center justify-center text-grove-600 mb-4">
              <Fragment set:html={step.icon} />
            </div>
            
            <div class="text-sm font-medium text-grove-600 mb-2">{step.number}</div>
            <h3 class="text-xl font-semibold text-warm-900 mb-2">{step.title}</h3>
            <p class="text-warm-600 text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
