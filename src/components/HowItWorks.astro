---
const steps = [
  {
    number: '01',
    title: 'Join Discord',
    description: 'Hop into our community. Introduce yourself, ask questions, and get the lay of the land.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>`
  },
  {
    number: '02',
    title: 'Pick a project',
    description: 'Browse active projects and find one that matches your interests and skill level. We\'ll help you find a good fit.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>`
  },
  {
    number: '03',
    title: 'Start contributing',
    description: 'Claim an issue, write some code, and open a PR. Your work ships to real users—not a practice sandbox.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`
  },
  {
    number: '04',
    title: 'Get mentorship',
    description: 'Receive code reviews, pair programming sessions, and career advice from engineers who\'ve been there.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`
  }
];
---

<section id="how-it-works" class="py-20 sm:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-warm-900 mb-4">
        How it works
      </h2>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto">
        No applications. No interviews. Just show up, pick something to work on, and start building.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div class="relative">
          <!-- Connector line (hidden on mobile, shown between items on desktop) -->
          {index < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-1/2 w-full h-0.5 bg-grove-200"></div>
          )}
          
          <div class="relative bg-warm-50 rounded-2xl p-6 h-full">
            <!-- Step number -->
            <div class="w-16 h-16 bg-grove-100 rounded-xl flex items-center justify-center text-grove-600 mb-4">
              <Fragment set:html={step.icon} />
            </div>
            
            <div class="text-sm font-medium text-grove-600 mb-2">{step.number}</div>
            <h3 class="text-xl font-semibold text-warm-900 mb-2">{step.title}</h3>
            <p class="text-warm-600 text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
