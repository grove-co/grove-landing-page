---
const tracks = [
  {
    emoji: '🛠️',
    name: 'Real Coding Experience',
    description: 'Contribute to live open-source projects with real users. Get code reviews from experienced developers, build your GitHub portfolio, and ship features that matter.',
    forYouIf: 'You want hands-on coding experience',
    commitment: 'Flexible, a few hours/week',
    highlights: ['Production codebases', 'Code reviews', 'Portfolio building']
  },
  {
    emoji: '💼',
    name: 'Career Mentorship',
    description: 'Get 1:1 mentorship focused on your career. Resume reviews, mock interviews, LinkedIn optimization, networking help, and advice from professionals in the industry.',
    forYouIf: 'You want career guidance (no coding required)',
    commitment: 'Occasional sessions',
    highlights: ['Resume feedback', 'Mock interviews', 'Networking help']
  },
  {
    emoji: '🎓',
    name: 'Transfer Support Network',
    description: 'Navigating the transfer process to a 4-year university? Get connected with students from our network of 1,600+ students who\'ve been through it and can help you find your footing.',
    forYouIf: 'You\'re a transfer student',
    commitment: 'Flexible, as needed',
    highlights: ['Peer connections', 'Campus insights', 'Transfer guidance']
  }
];
---

<section id="tracks" class="py-20 sm:py-28 bg-warm-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-warm-900 mb-4">
        Three ways to get involved
      </h2>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto">
        Everyone's journey is different. Choose what fits you—or try them all.
      </p>
    </div>

    <!-- Track Cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {tracks.map(track => (
        <div class="bg-white rounded-2xl p-8 border border-warm-200 hover:border-grove-300 transition-colors flex flex-col">
          <!-- Emoji -->
          <div class="text-4xl mb-4">{track.emoji}</div>

          <!-- Track info -->
          <h3 class="text-2xl font-semibold text-warm-900 mb-3">{track.name}</h3>
          <p class="text-warm-600 mb-6 leading-relaxed flex-grow">{track.description}</p>

          <!-- For you if -->
          <div class="mb-4">
            <span class="text-sm font-medium text-grove-700 bg-grove-50 px-3 py-1 rounded-full">
              {track.forYouIf}
            </span>
          </div>

          <!-- Highlights -->
          <div class="flex flex-wrap gap-2 mb-4">
            {track.highlights.map(highlight => (
              <span class="px-3 py-1 bg-warm-100 text-warm-700 rounded-lg text-sm">
                {highlight}
              </span>
            ))}
          </div>

          <!-- Commitment -->
          <p class="text-sm text-warm-500 mt-auto">
            <span class="font-medium">Commitment:</span> {track.commitment}
          </p>
        </div>
      ))}
    </div>

    <!-- Entry point callout -->
    <p class="text-center mt-12 text-warm-500">
      Not sure where to start? <a href="https://forms.example.com/grove-interest" target="_blank" rel="noopener noreferrer" class="text-grove-600 hover:underline">Fill out the interest form</a> and we'll help you find the right track for you.
    </p>
  </div>
</section>
