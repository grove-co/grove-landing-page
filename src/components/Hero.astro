---
---

<section class="relative overflow-hidden bg-gradient-to-b from-grove-50 to-warm-50 py-20 sm:py-28 lg:py-32">
  <!-- Subtle background pattern -->
  <div class="absolute inset-0 opacity-30">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgb(22 163 74 / 0.15) 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>
  
  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-grove-100 text-grove-700 px-4 py-1.5 rounded-full text-sm font-medium mb-8">
      <span class="w-2 h-2 bg-grove-500 rounded-full animate-pulse"></span>
      Open to all college students
    </div>

    <!-- Headline -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-warm-900 tracking-tight mb-6">
      Find your path.<br/>
      <span class="text-grove-600">Get real mentorship.</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-lg sm:text-xl text-warm-600 max-w-2xl mx-auto mb-10 leading-relaxed">
      Grove connects college students with working professionals and a supportive network. 
      Whether you want real coding experience, career mentorship, or transfer support—we've got a track for you.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a 
        href="#join" 
        class="w-full sm:w-auto bg-grove-600 hover:bg-grove-700 text-white px-8 py-3 rounded-lg font-semibold transition-colors flex items-center justify-center gap-2"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
        Join the Discord
      </a>
      <a 
        href="#tracks" 
        class="w-full sm:w-auto bg-white hover:bg-warm-100 text-warm-700 px-8 py-3 rounded-lg font-semibold transition-colors border border-warm-300"
      >
        Find your track
      </a>
    </div>

    <!-- Social proof hint -->
    <p class="mt-10 text-sm text-warm-500">
      No coding required. Just curiosity and a willingness to grow.
    </p>
  </div>
</section>
