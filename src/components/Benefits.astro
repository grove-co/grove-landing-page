---
const benefits = [
  {
    title: 'Portfolio-ready work',
    description: 'Ship features to production apps with real users. Your contributions show up on GitHub where recruiters actually look.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>`
  },
  {
    title: 'Real code reviews',
    description: 'Get feedback from senior engineers who do this professionally. Learn patterns, best practices, and the "why" behind good code.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`
  },
  {
    title: 'Professional references',
    description: 'Work with us consistently, and we\'ll vouch for you. References from working engineers carry weight with hiring managers.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`
  },
  {
    title: 'Genuine community',
    description: 'College can be isolating. Grove is a place where you belong—people who will celebrate your wins and help you through the hard parts.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`
  }
];
---

<section id="benefits" class="py-20 sm:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-warm-900 mb-4">
        What you actually get
      </h2>
      <p class="text-lg text-warm-600 max-w-2xl mx-auto">
        Not vague promises. Concrete things that help you land jobs and grow as an engineer.
      </p>
    </div>

    <!-- Benefits Grid -->
    <div class="grid sm:grid-cols-2 gap-8">
      {benefits.map(benefit => (
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-12 h-12 bg-grove-100 rounded-xl flex items-center justify-center text-grove-600">
            <Fragment set:html={benefit.icon} />
          </div>
          <div>
            <h3 class="text-xl font-semibold text-warm-900 mb-2">{benefit.title}</h3>
            <p class="text-warm-600 leading-relaxed">{benefit.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- What we're NOT -->
    <div class="mt-16 p-8 bg-warm-100 rounded-2xl">
      <h3 class="text-xl font-semibold text-warm-900 mb-4">What Grove is NOT:</h3>
      <ul class="grid sm:grid-cols-3 gap-4">
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-warm-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          <span class="text-warm-700">A coding bootcamp or tutoring service</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-warm-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          <span class="text-warm-700">Unpaid labor disguised as opportunity</span>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-5 h-5 text-warm-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          <span class="text-warm-700">A bait-and-switch for forced conversations</span>
        </li>
      </ul>
    </div>
  </div>
</section>
