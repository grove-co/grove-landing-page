<section id="join" class="py-20 sm:py-28 bg-grove-700">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Headline -->
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
      Ready to find your path?
    </h2>
    
    <p class="text-lg text-grove-100 max-w-2xl mx-auto mb-10">
      Join a network of students and professionals who are here to help you grow—whether that's through coding, career support, or transfer guidance.
    </p>

    <!-- Form CTA -->
    <a 
      href="https://forms.example.com/grove-interest" 
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 bg-white hover:bg-grove-50 text-grove-700 px-8 py-4 rounded-xl font-semibold text-lg transition-colors"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
      </svg>
      Fill Out the Interest Form
    </a>

    <p class="mt-6 text-sm text-grove-200">
      Takes less than a minute. We'll follow up personally.
    </p>
  </div>
</section>
