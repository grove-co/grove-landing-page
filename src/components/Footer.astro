---
const currentYear = new Date().getFullYear();
---

<footer class="bg-warm-900 text-warm-400 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-white font-semibold text-lg">
        <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M16 2C16 2 8 8 8 16C8 20.4183 11.5817 24 16 24C20.4183 24 24 20.4183 24 16C24 8 16 2 16 2Z" fill="currentColor" fill-opacity="0.2"/>
          <path d="M16 6C16 6 11 10 11 15C11 17.7614 13.2386 20 16 20C18.7614 20 21 17.7614 21 15C21 10 16 6 16 6Z" fill="currentColor"/>
          <path d="M16 24V30M16 30L13 27M16 30L19 27" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Grove
      </a>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm">
        <a href="#how-it-works" class="hover:text-white transition-colors">How It Works</a>
        <a href="#projects" class="hover:text-white transition-colors">Projects</a>
        <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
        <a 
          href="https://github.com/grove-co" 
          target="_blank" 
          rel="noopener noreferrer"
          class="hover:text-white transition-colors"
        >
          GitHub
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-sm">
        © {currentYear} Grove. Made with care.
      </p>
    </div>
  </div>
</footer>
